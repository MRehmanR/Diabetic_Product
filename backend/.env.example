APP_NAME="Diabetic Supplies Buy-Back API"
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/diabetic_buyback
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BACKEND_CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|0\.0\.0\.0|192\.168\.\d+\.\d+|10\.\d+\.\d+\.\d+|172\.(1[6-9]|2\d|3[0-1])\.\d+\.\d+):\d+$
UPLOAD_DIR=app/uploads
PUBLIC_UPLOAD_BASE_URL=http://localhost:8000/uploads
MAX_UPLOAD_SIZE_MB=5
SEED_ADMIN_EMAIL=admin@diabcare.com
SEED_ADMIN_PASSWORD=admin123
FRONTEND_URL=http://127.0.0.1:5173
PASSWORD_RESET_EXPIRE_MINUTES=30
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@diabeticproductbuyers.com
SMTP_USE_TLS=true
